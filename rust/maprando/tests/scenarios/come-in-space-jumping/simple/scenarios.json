{
  "$schema": "../../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Without Disable Equipment",
      "globalState": {
        "disabledTech": ["canDisableEquipment"],
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2
    },
    {
      "name": "Lose Blue Suit",
      "globalState": {
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "blueSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "reverse": "weak"
    },
    {
      "name": "Keep Flash Suit",
      "globalState": {
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "flashSuit": 1
      }
    },
    {
      "name": "Lose Flash Suit: No Tricky Carry Tech",
      "globalState": {
        "disabledTech": ["canTrickyCarryFlashSuit"],
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "reverse": "weak"
    },
    {
      "name": "Fail: No Tricky Carry Flash Suit",
      "globalState": {
        "disabledTech": ["canTrickyCarryFlashSuit"],
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "flashSuit": 1
      },
      "fail": true
    },
    {
      "name": "Fail: Cannot Keep Blue Suit",
      "globalState": {
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "blueSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "blueSuit": 1
      },
      "fail": true
    },
    {
      "name": "Fail: No Space Jump",
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: No Side Platform Tech",
      "globalState": {
        "disabledTech": ["canSidePlatformCrossRoomJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    }
  ]
}