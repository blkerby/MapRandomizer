{
  "$schema": "../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Fail: No Weapons",
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: Grapple (Invulnerable)",
      "globalState": {
        "items": ["Grapple"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: Full Beam (Invulnerable)",
      "globalState": {
        "items": ["Charge", "Wave", "Ice", "Spazer", "Plasma"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Missile",
      "globalState": {
        "maxMissiles": 5
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "startState": {
        "missiles": {"remaining": 4}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Supers",
      "globalState": {
        "maxSupers": 5
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "startState": {
        "supers": {"remaining": 4}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Power Bombs",
      "globalState": {
        "items": ["Morph"],
        "maxPowerBombs": 5
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "startState": {
        "powerBombs": {"remaining": 3}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Fail: Power Bombs without Morph",
      "globalState": {
        "maxPowerBombs": 5
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "startState": {
        "powerBombs": {"remaining": 3}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Bombs",
      "globalState": {
        "items": ["Morph", "Bombs"]
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Fail: Bombs without Morph",
      "globalState": {
        "items": ["Bombs"]
      },
      "startRoomId": 0 ,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Prefer Missiles over Other Ammo",
      "globalState": {
        "maxMissiles": 5,
        "maxSupers": 5,
        "maxPowerBombs": 5
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "missiles": {"remaining": 5},
        "supers": {"remaining": 5},
        "powerBombs": {"remaining": 5}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "missiles": {"remaining": 1},
        "supers": {"remaining": 5},
        "powerBombs": {"remaining": 5}
      }
    },
    {
      "name": "Prefer Supers over Power Bombs",
      "globalState": {
        "maxSupers": 5,
        "maxPowerBombs": 5
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "supers": {"remaining": 5},
        "powerBombs": {"remaining": 5}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "supers": {"remaining": 1},
        "powerBombs": {"remaining": 5}
      }
    }
