{
  "$schema": "../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Not Enough Energy",
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "energy": {"remaining": 30}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Enough Energy",
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "energy": {"remaining": 31}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Varia Only",
      "globalState": {
        "items": ["Varia"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "energy": {"remaining": 16}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Gravity Only",
      "globalState": {
        "items": ["Gravity"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "energy": {"remaining": 16}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Both Suits",
      "globalState": {
        "items": ["Varia", "Gravity"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "energy": {"remaining": 8}
      },
      "endRoomId": 0,
      "endNodeId": 2
    }
  ]
}