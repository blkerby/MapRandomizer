{
  "$schema": "../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Fail: Too Little Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 49}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Minimal Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 50}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "energy": {"remaining": 50}
      }
    },
    {
      "name": "Overfull Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 80}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "energy": {"remaining": 70}
      },
      "reverse": "weak"
    }
  ]
}