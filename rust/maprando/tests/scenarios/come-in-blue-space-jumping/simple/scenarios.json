{
  "$schema": "../../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Without Disable Equipment",
      "globalState": {
        "disabledTech": ["canDisableEquipment"],
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2
    },
    {
      "name": "Blue Booster",
      "globalState": {
        "items": ["SpaceJump", "BlueBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2
    },
    {
      "name": "Fail: Spark Booster",
      "globalState": {
        "items": ["SpaceJump", "SparkBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: Too Short of Runway",
      "settings": {
        "shinechargeTiles": 21
      },
      "globalState": {
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Lose Blue Suit",
      "globalState": {
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "blueSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "reverse": "weak"
    },
    {
      "name": "Keep Flash Suit",
      "globalState": {
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "flashSuit": 1
      }
    },
    {
      "name": "Lose Flash Suit: No Tricky Carry Tech",
      "globalState": {
        "disabledTech": ["canTrickyCarryFlashSuit"],
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "reverse": "weak"
    },
    {
      "name": "Fail: No Tricky Carry Flash Suit",
      "globalState": {
        "disabledTech": ["canTrickyCarryFlashSuit"],
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "flashSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "flashSuit": 1
      },
      "fail": true
    },
    {
      "name": "Fail: Cannot Keep Blue Suit",
      "globalState": {
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "blueSuit": 2
      },
      "endRoomId": 1,
      "endNodeId": 2,
      "endState": {
        "blueSuit": 1
      },
      "fail": true
    },
    {
      "name": "Fail: No Space Jump",
      "globalState": {
        "items": ["SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: No Speed Booster",
      "globalState": {
        "items": ["SpaceJump"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Fail: No Side Platform Tech",
      "globalState": {
        "disabledTech": ["canSidePlatformCrossRoomJump"],
        "items": ["SpaceJump", "SpeedBooster"]
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 1,
      "endNodeId": 2,
      "fail": true
    }
  ]
}