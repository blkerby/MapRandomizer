{
  "$schema": "../../../schema/scenarios.schema.json",
  "scenarios": [
    {
      "name": "Fail: No Reserves",
      "startRoomId": 0,
      "startNodeId": 1,
      "endRoomId": 0,
      "endNodeId": 2,
      "fail": true
    },
    {
      "name": "Minimal Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 1}
      },
      "endRoomId": 0,
      "endNodeId": 2
    },
    {
      "name": "Some Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 20}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "energy": {"remaining": 20}
      }
    },
    {
      "name": "Full Reserves",
      "globalState": {
        "maxReserves": 100
      },
      "startRoomId": 0,
      "startNodeId": 1,
      "startState": {
        "reserves": {"remaining": 100}
      },
      "endRoomId": 0,
      "endNodeId": 2,
      "endState": {
        "energy": {"remaining": 99}
      },
      "reverse": "weak"
    }
  ]
}